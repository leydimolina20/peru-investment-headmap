   "source": [
    "# 🦟 Heatmap Temporal — Dengue en el Perú (2000–2024)\n",
    "\n",
    "Visualización geoespacial animada de la propagación del dengue en el Perú a lo largo de 25 años.\n",
    "\n",
    "**Fuente de datos:** CDC MINSA — Red Nacional de Epidemiología (RENACE)  \n",
    "**Georreferenciación:** Tabla UBIGEO–Coordenadas (jmcastagnetto/ubigeo-peru-aumentado)  \n",
    "**Autor:** Leo Molina (@leydimolina20)\n",
    "\n",
    "---\n",
    "▶️ **Ejecuta las 3 celdas en orden.**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELDA 1: Dependencias ────────────────────────────────────────────────────\n",
    "!pip install folium --quiet"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELDA 2: Carga y procesamiento ───────────────────────────────────────────\n",
    "import requests, io, warnings\n",
    "import pandas as pd\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ── 2a. Cargar dataset dengue desde GitHub ────────────────────────────────────\n",
    "print('⏳ Descargando dataset de dengue...')\n",
    "BASE = 'https://raw.githubusercontent.com/leydimolina20/peru-investment-headmap/main/data'\n",
    "parts = [\n",
    "    f'{BASE}/dengue_part1of3.gz',\n",
    "    f'{BASE}/dengue_part2of3.gz',\n",
    "    f'{BASE}/dengue_part3of3.gz',\n",
    "]\n",
    "import gzip\n",
    "raw = b''.join(requests.get(url).content for url in parts)\n",
    "df_raw = pd.read_csv(\n",
    "    io.BytesIO(gzip.decompress(raw)),\n",
    "    encoding='latin1', sep=';', low_memory=False\n",
    ")\n",
    "df_raw.rename(columns={'\\ufeffdepartamento': 'departamento',\n",
    "                        'ï»¿departamento': 'departamento'}, inplace=True)\n",
    "df_raw.columns = [c.replace('ï»¿','') for c in df_raw.columns]\n",
    "print(f'✅ {len(df_raw):,} registros cargados | {df_raw[\"ano\"].min()}–{df_raw[\"ano\"].max()}')\n",
    "\n",
    "# ── 2b. Tabla UBIGEO → coordenadas (GitHub público) ──────────────────────────\n",
    "print('⏳ Descargando tabla de coordenadas por distrito...')\n",
    "url_geo = 'https://raw.githubusercontent.com/jmcastagnetto/ubigeo-peru-aumentado/main/ubigeo_distrito.csv'\n",
    "geo = pd.read_csv(url_geo)\n",
    "geo['inei_int'] = pd.to_numeric(geo['inei'], errors='coerce').astype('Int64')\n",
    "geo = geo[['inei_int','latitude','longitude']].dropna()\n",
    "\n",
    "# ── 2c. Cruzar y agregar por año-distrito ────────────────────────────────────\n",
    "df_raw['ubigeo_int'] = pd.to_numeric(df_raw['ubigeo'], errors='coerce').astype('Int64')\n",
    "casos = df_raw.groupby(['ano','ubigeo_int']).size().reset_index(name='casos')\n",
    "casos = casos.merge(geo, left_on='ubigeo_int', right_on='inei_int', how='inner')\n",
    "print(f'✅ {len(casos):,} registros georreferenciados | cobertura: {100*casos[\"casos\"].sum()/len(df_raw):.1f}%')\n",
    "print(f'📍 Años disponibles: {casos[\"ano\"].min()}–{casos[\"ano\"].max()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELDA 3: Heatmap animado por año ─────────────────────────────────────────\n",
    "import folium\n",
    "from folium.plugins import HeatMapWithTime, Fullscreen, MiniMap\n",
    "\n",
    "YEARS = sorted(casos['ano'].unique())\n",
    "\n",
    "# Normalizar peso por año (percentil 95 para evitar distorsión)\n",
    "heat_data = []\n",
    "for yr in YEARS:\n",
    "    sub = casos[casos['ano'] == yr].copy()\n",
    "    cap = sub['casos'].quantile(0.95)\n",
    "    sub['peso'] = (sub['casos'].clip(upper=cap) / cap).fillna(0.05)\n",
    "    heat_data.append(sub[['latitude','longitude','peso']].values.tolist())\n",
    "\n",
    "# Mapa base\n",
    "m = folium.Map(\n",
    "    location=[-9.5, -74.5],\n",
    "    zoom_start=5,\n",
    "    tiles='CartoDB dark_matter'\n",
    ")\n",
    "\n",
    "# HeatMap animado\n",
    "HeatMapWithTime(\n",
    "    data=heat_data,\n",
    "    index=[str(y) for y in YEARS],\n",
    "    radius=18,\n",
    "    blur=15,\n",
    "    max_opacity=0.85,\n",
    "    min_opacity=0.1,\n",
    "    gradient={0.2:'#1565C0', 0.4:'#26A69A', 0.6:'#FFC107', 0.8:'#FF5722', 1.0:'#B71C1C'},\n",
    "    auto_play=True,\n",
    "    display_index=True,\n",
    "    time_interval=800,\n",
    "    speed_step=0.1,\n",
    ").add_to(m)\n",
    "\n",
    "# Controles\n",
    "Fullscreen(position='topright', title='Pantalla completa',\n",
    "           title_cancel='Salir', force_separate_button=True).add_to(m)\n",
    "MiniMap(toggle_display=True, position='bottomleft').add_to(m)\n",
    "\n",
    "# Título\n",
    "m.get_root().html.add_child(folium.Element(\"\"\"\n",
    "<div style=\"position:fixed;top:10px;left:50px;z-index:9999;\n",
    "    background:rgba(0,0,0,0.80);padding:12px 18px;border-radius:8px;\n",
    "    color:white;font-family:Arial;box-shadow:0 2px 8px rgba(0,0,0,0.5)\">\n",
    "  <h3 style=\"margin:0;font-size:17px\">🦟 Propagación del Dengue en el Perú</h3>\n",
    "  <p style=\"margin:4px 0 0 0;font-size:11px;color:#80DEEA\">\n",
    "    2000–2024 · 1 millón de casos · Intensidad = N° casos por distrito\n",
    "  </p>\n",
    "</div>\"\"\"))\n",
    "\n",
    "# Fuente\n",
    "m.get_root().html.add_child(folium.Element(\"\"\"\n",
    "<div style=\"position:fixed;top:10px;right:50px;z-index:9999;\n",
    "    color:#ccc;font-family:Arial;font-size:11px;\n",
    "    background:rgba(0,0,0,0.55);padding:6px 10px;border-radius:5px\">\n",
    "  Fuente: CDC MINSA–RENACE | Elaborado por: Leo Molina\n",
    "</div>\"\"\"))\n",
    "\n",
    "# Leyenda\n",
    "m.get_root().html.add_child(folium.Element(\"\"\"\n",
    "<div style=\"position:fixed;bottom:60px;right:10px;z-index:9999;\n",
    "    background:rgba(0,0,0,0.75);padding:10px 14px;border-radius:7px;\n",
    "    color:white;font-family:Arial;font-size:11px\">\n",
    "  <b>Densidad de casos</b><br>\n",
    "  <span style='color:#B71C1C'>■</span> Muy alta<br>\n",
    "  <span style='color:#FF5722'>■</span> Alta<br>\n",
    "  <span style='color:#FFC107'>■</span> Media<br>\n",
    "  <span style='color:#26A69A'>■</span> Baja<br>\n",
    "  <span style='color:#1565C0'>■</span> Muy baja\n",
    "</div>\"\"\"))\n",
    "\n",
    "m.save('dengue_heatmap_peru.html')\n",
    "print('✅ Mapa guardado como: dengue_heatmap_peru.html')\n",
    "m"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── CELDA 4 (opcional): Resumen estadístico por año ──────────────────────────\n",
    "resumen = (\n",
    "    df_raw.groupby('ano')\n",
    "    .agg(\n",
    "        total_casos=('ubigeo','count'),\n",
    "        distritos_afectados=('ubigeo','nunique'),\n",
    "    )\n",
    "    .reset_index()\n",
    "    .rename(columns={'ano':'Año','total_casos':'Total casos','distritos_afectados':'Distritos afectados'})\n",
    ")\n",
    "print('Evolución histórica del dengue en Perú (2000–2024)')\n",
    "resumen"
   ]
  }
 ],
